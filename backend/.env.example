# Backend API (Vite proxies /api here in development)
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
APP_URL=http://localhost:3001

# Aiven PostgreSQL — copy your connection string from the Aiven console
DATABASE_URL=postgres://user:password@host:port/defaultdb?sslmode=require

# Optional: force SSL when not using sslmode=require in the URL
# DATABASE_SSL=true
